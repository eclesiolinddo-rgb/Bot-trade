TELEGRAM_TOKEN=your-telegram-bot-token
# Path to Firebase service account JSON file or use default application credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccount.json
# Comma-separated list of admin telegram chat IDs
ADMIN_CHAT_IDS=123456789,987654321
# Base URL of the web app where the user will confirm the link token
BASE_APP_URL=https://clesscripto.app
# Optional: confirmation timeout in seconds (default 600 = 10min)
CONFIRM_TIMEOUT_SECONDS=600
